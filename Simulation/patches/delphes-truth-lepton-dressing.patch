 //------------------------------------------------------------------------------
+
+Bool_t LeptonDressing::IsHadron(Int_t pid) const
+{
+  const Int_t absolutePID = TMath::Abs(pid);
+  return (absolutePID >= 100 && absolutePID < 1000000) || absolutePID >= 1000000000;
+}
+
+//------------------------------------------------------------------------------
+
+void LeptonDressing::AddMothers(const Candidate *candidate, vector<Int_t> &indices) const
+{
+  const Int_t size = fParticleInputArray->GetEntriesFast();
+  const Int_t first = candidate->M1;
+  const Int_t last = candidate->M2 >= first ? candidate->M2 : first;
+
+  if(first >= 0)
+  {
+    for(Int_t index = first; index <= last && index < size; ++index) indices.push_back(index);
+  }
+  else if(candidate->M2 >= 0 && candidate->M2 < size)
+  {
+    indices.push_back(candidate->M2);
+  }
+}
+
+//------------------------------------------------------------------------------
+
+Bool_t LeptonDressing::HasHadronAncestor(const Candidate *candidate) const
+{
+  vector<Int_t> pending;
+  set<Int_t> visited;
+  AddMothers(candidate, pending);
+
+  while(!pending.empty())
+  {
+    const Int_t index = pending.back();
+    pending.pop_back();
+    if(index < 0 || index >= fParticleInputArray->GetEntriesFast()) continue;
+    if(!visited.insert(index).second) continue;
+
+    const Candidate *ancestor = static_cast<const Candidate *>(fParticleInputArray->At(index));
+    if(!ancestor) continue;
+    if(IsHadron(ancestor->PID)) return true;
+    AddMothers(ancestor, pending);
+  }
+  return false;
+}
